#!/bin/bash

SESSION="main"

# Check if session exists
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  # Create new session, detached
  # This will load ~/.tmux.conf automatically if it exists
  tmux new-session -d -s "$SESSION"

  # We assume base-index 1 and pane-base-index 1 from your config.
  # Initial state: Window 1, Pane 1 (Full screen)

  # Create 3 side-by-side panes of equal width (33% each)

  # 1. Split Pane 1 horizontally, giving the new pane (Pane 2) 66% of the width.
  # Result: Pane 1 (Left, 34%), Pane 2 (Right, 66%)
  tmux split-window -h -p 66 -t "$SESSION:1.1"

  # 2. Split Pane 2 horizontally, giving the new pane (Pane 3) 50% of Pane 2's width.
  # Result: Pane 1 (Left, ~33%), Pane 2 (Middle, ~33%), Pane 3 (Right, ~33%)
  tmux split-window -h -p 50 -t "$SESSION:1.2"

  # Connect to dev vm in the middle pane (Pane 2)
  tmux send-keys -t "$SESSION:1.2" "ssh-dev-vm" C-m

  # SSH into cloudtop instance in the rightmost pane (Pane 3)
  tmux send-keys -t "$SESSION:1.3" "ssh robedwards.c.googlers.com" C-m

  # Select the first pane (Left) to start
  tmux select-pane -t "$SESSION:1.1"
fi

# Attach to the session
# 'exec' replaces the current shell, so closing tmux closes the terminal tab
exec tmux attach-session -t "$SESSION"
